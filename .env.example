# =============================================================================
# Waseller — environment template. Copy to .env (never commit .env).
# =============================================================================

WASELLER_ENV=local
WASELLER_LOG_LEVEL=INFO

# --- PostgreSQL ------------------------------------------------------------
WASELLER_POSTGRES_URL=postgresql+asyncpg://waseller:waseller@localhost:5432/waseller

# --- Redis (Celery broker) -------------------------------------------------
WASELLER_REDIS_URL=redis://localhost:6379/0

# --- LLM routing (OpenRouter) ----------------------------------------------
# Model routing sorts by price per the spec.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Multimodal extraction (optional; mocked in local) ---------------------
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- WhatsApp / Meta (set at deploy; mocked in local) ----------------------
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
KAPSO_GATEWAY_URL=http://localhost:4000

# --- Security (Fase 13) ----------------------------------------------------
# 32-byte base64-urlsafe key. Generate with:
#   python -c "from waseller.security import generate_key; print(generate_key())"
WASELLER_ENCRYPTION_KEY=

# --- Rate limiting (per-IP). memory:// for single-process; redis://... for prod
WASELLER_RATE_LIMIT_STORAGE=memory://
WASELLER_RATE_LIMIT_DEFAULT=120/minute
WASELLER_RATE_LIMIT_WEBHOOK=600/minute
WASELLER_RATE_LIMIT_ONBOARD=30/minute

# --- Dashboard / CORS ------------------------------------------------------
# Comma-separated origins allowed to call the API from a browser.
WASELLER_DASHBOARD_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
