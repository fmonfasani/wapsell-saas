# =============================================================================
# Waseller — environment template. Copy to .env (never commit .env).
#
# Sections grouped by ORIGEN del secret:
#   - "GENERATED" = lo generás vos en la VPS al hacer bootstrap (random/openssl)
#   - "META"      = lo sacás de developers.facebook.com (App Settings / WhatsApp setup)
#   - "OPENROUTER"= lo sacás de openrouter.ai/keys
#   - "INFRA"     = config interno de tu deploy (postgres/redis URLs, dominios)
#
# REQUIRED para arrancar el container:  POSTGRES_PASSWORD + WASELLER_ENCRYPTION_KEY
# REQUIRED para webhook real:           + META_APP_SECRET + META_VERIFY_TOKEN
# REQUIRED para responder con LLM real: + OPENROUTER_API_KEY  (sin esto = EchoLLM)
# REQUIRED para enviar mensajes:        + META_ACCESS_TOKEN + META_PHONE_NUMBER_ID
#                                         (todavía no leídos por el código — futuro)
# =============================================================================

WASELLER_ENV=local
WASELLER_LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# GENERATED — secrets que generás al deployar (no vienen de ningún servicio)
# -----------------------------------------------------------------------------

# Password de postgres. Generá con:  openssl rand -hex 24
POSTGRES_PASSWORD=
POSTGRES_DB=waseller
POSTGRES_USER=waseller

# Clave de cifrado de tokens (AES-256-GCM). 32 bytes base64-urlsafe.
# Generá con:  python -c "from waseller.security import generate_key; print(generate_key())"
WASELLER_ENCRYPTION_KEY=

# Token que vos elegís + le pegás a Meta cuando configurás el webhook.
# Tiene que matchear en ambos lados. Generá con:  openssl rand -hex 16
META_VERIFY_TOKEN=


# -----------------------------------------------------------------------------
# META — developers.facebook.com → tu app → ...
# -----------------------------------------------------------------------------

# App Settings → Basic → "App Secret" (botón Mostrar, te pide tu password)
META_APP_SECRET=

# WhatsApp → Configuración básica → Paso 1. Pruébalo
# "Token de acceso temporal" (caduca 24h) o System User token (permanente)
META_ACCESS_TOKEN=

# WhatsApp → Configuración básica → Paso 1. Pruébalo
# "Phone number ID" — el número de test que Meta te regaló (o tu prod number)
META_PHONE_NUMBER_ID=

# WhatsApp → Configuración básica → Paso 1. Pruébalo
# "WhatsApp Business Account ID" (WABA ID)
META_WABA_ID=


# -----------------------------------------------------------------------------
# OPENROUTER — openrouter.ai/keys (vacío = EchoLLM fallback determinístico)
# -----------------------------------------------------------------------------

# Routing por precio: la API elige el modelo más barato que cumpla la capacidad.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku


# -----------------------------------------------------------------------------
# MULTIMODAL — opcionales, solo para extraer audio/imagen/video.
# Sin keys, los extractores usan mocks (suficiente para texto + PDF + CSV + DOCX)
# -----------------------------------------------------------------------------

GEMINI_API_KEY=
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# KAPSO — gateway WhatsApp self-hosted (opcional; sin esto usa Cloud API directa)
# -----------------------------------------------------------------------------

KAPSO_GATEWAY_URL=


# -----------------------------------------------------------------------------
# INFRA — config interno de tu deploy
# -----------------------------------------------------------------------------

# Connection strings (en docker-compose se autoarman desde POSTGRES_*)
WASELLER_POSTGRES_URL=postgresql+asyncpg://waseller:waseller@localhost:5432/waseller
WASELLER_REDIS_URL=redis://localhost:6379/0

# Rate limiting (per-IP). memory:// es OK para 1 worker; redis://... para multi-worker.
# Nota: redis:// requiere `pip install redis` (no incluido en core deps de waseller hoy).
WASELLER_RATE_LIMIT_STORAGE=memory://
WASELLER_RATE_LIMIT_DEFAULT=120/minute
WASELLER_RATE_LIMIT_WEBHOOK=600/minute
WASELLER_RATE_LIMIT_ONBOARD=30/minute

# CORS (orígenes que pueden llamar a la API desde un browser).
# En prod: la URL del admin dashboard. En dev: localhost:3000.
WASELLER_DASHBOARD_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
