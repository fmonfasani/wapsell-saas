# =============================================================================
# HermesSell — environment template. Copy to .env (never commit .env).
# =============================================================================

HERMESELL_ENV=local
HERMESELL_LOG_LEVEL=INFO

# --- PostgreSQL ------------------------------------------------------------
HERMESELL_POSTGRES_URL=postgresql+asyncpg://hermesell:hermesell@localhost:5432/hermesell

# --- Redis (Celery broker) -------------------------------------------------
HERMESELL_REDIS_URL=redis://localhost:6379/0

# --- LLM routing (OpenRouter) ----------------------------------------------
# Model routing sorts by price per the spec.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Multimodal extraction (optional; mocked in local) ---------------------
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- WhatsApp / Meta (set at deploy; mocked in local) ----------------------
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
KAPSO_GATEWAY_URL=http://localhost:4000
